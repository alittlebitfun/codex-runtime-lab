# PostgreSQL
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=codex_lab
PGUSER=postgres
PGPASSWORD=your_password_here

# JWT Authentication (required, use a long random string)
JWT_SECRET=your_random_secret_key_here

# Server
PORT=8765
MAX_CONCURRENT_SESSIONS=1

# Codex CLI runtime
# On macOS/Homebrew this is usually /opt/homebrew/bin/codex.
# Leave empty to let the server auto-detect or fall back to npx.
CODEX_BIN=
CODEX_MODEL=gpt-5.3-codex-spark
CODEX_MODELS=gpt-5.3-codex-spark,gpt-5.5
CODEX_SERVICE_TIER=fast
CODEX_TASK_TIMEOUT_MS=600000
CODEX_SPAWN_RETRIES=6
CODEX_SPAWN_RETRY_BASE_MS=2000
CODEX_WORKSPACE_ROOT=./runtime-sandboxes
CODEX_RUNTIME_HOME=./.codex-runtime-home
USER_CODEX_HOME=
