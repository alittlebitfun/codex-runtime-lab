# PostgreSQL
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=codex_lab
PGUSER=postgres
PGPASSWORD=your_password_here

# JWT Authentication (required, use a long random string)
JWT_SECRET=your_random_secret_key_here

# Server
PORT=8765

# Codex Runtime (optional)
CODEX_RUNTIME_BASE=http://127.0.0.1:8080/v1
CODEX_RUNTIME_API_KEY=
CODEX_MODEL=gpt-5.3-codex-spark
MAX_CONCURRENT_SESSIONS=4
